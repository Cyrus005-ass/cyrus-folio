# Configuration par defaut pour le demarrage local.
# Si ton .env contient deja les valeurs de production, cree plutot un .env.local : il est charge en local apres .env.
# Local WAMP : APP_URL=http://localhost/portfolio-os
# Production : APP_ENV=production, APP_DEBUG=false, ASSET_MINIFY=true, APP_URL=https://cyrusportfolio.unaux.com

APP_NAME=Cyrus-y ASSOGBA
APP_URL=http://localhost/portfolio-os
APP_ENV=local
APP_DEBUG=true
ASSET_MINIFY=false
APP_AUTHOR=Cyrus-y ASSOGBA
APP_LOCALE=fr_FR
APP_DESCRIPTION=Portfolio officiel de Cyrus-y ASSOGBA, developpeur fullstack base a Cotonou.
APP_KEYWORDS=portfolio, Cyrus-y ASSOGBA, developpeur fullstack, web, projets, certifications
# Local : noindex,nofollow | Production : index,follow
APP_ROBOTS=noindex,nofollow
APP_OG_IMAGE=
APP_TWITTER_HANDLE=
APP_THEME_COLOR=#2563eb
APP_FAVICON_ICO=favicon.ico
APP_FAVICON_SVG=assets/icons/favicon.svg
APP_FAVICON_32=assets/icons/favicon-32x32.png
APP_FAVICON_16=assets/icons/favicon-16x16.png
APP_APPLE_TOUCH_ICON=assets/icons/apple-touch-icon.png
APP_MASK_ICON=assets/icons/safari-pinned-tab.svg
APP_WEBMANIFEST=assets/icons/site.webmanifest
APP_EXTERNAL_FONTS=true
# Coupe la video du logo pour alleger la navigation publique.
APP_BRAND_VIDEO=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=portfolio_os
DB_USER=root
DB_PASSWORD=

# Mets true temporairement pour creer le premier admin, puis repasse a false.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_NAME=Cyrus-y ASSOGBA
ADMIN_BOOTSTRAP_EMAIL=admin@portfolio.local
ADMIN_BOOTSTRAP_PASSWORD=change_me_before_first_login
TWO_FACTOR_ISSUER=Cyrus-y ASSOGBA Admin

MAIL_MAILER=smtp
MAIL_FROM=youraddress@gmail.com
MAIL_FROM_NAME=Cyrus-y ASSOGBA
MAIL_TO=you@example.com
MAIL_TO_NAME=Cyrus-y ASSOGBA
MAIL_REPLY_TO=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=youraddress@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT=15
MAIL_VERIFY_PEER=true

DASHBOARD_UNREAD_ALERT_DAYS=3
POST_VIEW_NOTIFICATION_THRESHOLDS=10,50,100,250,500

GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
# Alternative plus poussee si tu veux plus de raisonnement : openai/gpt-oss-120b
GROQ_TIMEOUT=20
GROQ_API_KEY=replace_with_groq_api_key
# Protection du widget chatbot en prod (fen?tre glissante).
CHATBOT_WINDOW_SECONDS=300
CHATBOT_MAX_MESSAGES=24

# Firebase admin / auth
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=storage/secure/firebase-service-account.json
# Optionnel : la doc Google/Firebase recommande aussi GOOGLE_APPLICATION_CREDENTIALS et GOOGLE_CLOUD_PROJECT.
# GOOGLE_APPLICATION_CREDENTIALS=storage/secure/firebase-service-account.json
# GOOGLE_CLOUD_PROJECT=mon-portfolio-3f510
FIREBASE_STORAGE_BUCKET=
FIREBASE_REQUIRE_VERIFIED_EMAIL=true
FIREBASE_AUTO_PROVISION=false
FIREBASE_AUTO_PROVISION_ROLE=super_admin
FIREBASE_TIMEOUT=20
FIREBASE_CA_BUNDLE=
FIREBASE_MESSAGES_SYNC=true
FIREBASE_MESSAGES_COLLECTION=messages
