# Base unique de configuration.
# Copie ce fichier vers .env puis adapte les valeurs a ton environnement.
# Local : APP_ENV=local, APP_DEBUG=true, APP_URL=http://localhost/portfolio-os
# Production : APP_ENV=production, APP_DEBUG=false, APP_URL=https://ton-domaine.com

APP_NAME=Cyrus-y ASSOGBA
APP_URL=http://localhost/portfolio-os
APP_ENV=local
APP_DEBUG=true
APP_AUTHOR=Cyrus-y ASSOGBA
APP_LOCALE=fr_FR
APP_DESCRIPTION=Portfolio officiel de Cyrus-y ASSOGBA, developpeur fullstack base a Cotonou.
APP_KEYWORDS=portfolio, Cyrus-y ASSOGBA, developpeur fullstack, web, projets, certifications
# Local : noindex,nofollow | Production : index,follow
APP_ROBOTS=noindex,nofollow
APP_OG_IMAGE=
APP_TWITTER_HANDLE=
APP_THEME_COLOR=#2563eb

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=portfolio_os
DB_USER=root
DB_PASSWORD=

# Mets true temporairement pour creer le premier admin, puis repasse a false.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_NAME=Cyrus-y ASSOGBA
ADMIN_BOOTSTRAP_EMAIL=admin@portfolio.local
ADMIN_BOOTSTRAP_PASSWORD=change_me_before_first_login

MAIL_MAILER=smtp
MAIL_FROM=youraddress@gmail.com
MAIL_FROM_NAME=Cyrus-y ASSOGBA
MAIL_TO=you@example.com
MAIL_TO_NAME=Cyrus-y ASSOGBA
MAIL_REPLY_TO=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=youraddress@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT=15
MAIL_VERIFY_PEER=true

DASHBOARD_UNREAD_ALERT_DAYS=3
POST_VIEW_NOTIFICATION_THRESHOLDS=10,50,100,250,500

GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
# Alternative plus poussee si tu veux plus de raisonnement : openai/gpt-oss-120b
GROQ_TIMEOUT=20
GROQ_API_KEY=replace_with_groq_api_key

