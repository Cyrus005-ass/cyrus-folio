AddType application/manifest+json .webmanifest
RewriteEngine On

# Bloque les dotfiles, les outils de dev et les dossiers applicatifs hors public.
RewriteRule (^|/)\. - [F,L]
RewriteRule ^(app|config|database|resources|storage|vendor|node_modules|scripts)/ - [F,L,NC]
RewriteRule ^public/ - [F,L,NC]
RewriteRule ^(?:composer\.(?:json|lock)|package(?:-lock)?\.json|README(?:\.[^/]+)?|.*\.(?:md|sql|log|ini|bak|dist|ya?ml))$ - [F,L,NC]

# Sert les fichiers statiques du dossier public sans exposer les autres repertoires.
RewriteRule ^(assets/.+)$ public/$1 [L,NC]
RewriteRule ^(favicon\.ico|robots\.txt)$ public/$1 [L,NC]
RewriteRule ^cript\.php$ public/cript.php [L,NC]

# Route toutes les URL applicatives vers le front-controller racine.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^$ index.php [L]
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]