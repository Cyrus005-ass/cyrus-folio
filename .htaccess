RewriteEngine On

# Bloque les dotfiles et les dossiers applicatifs hors public.
RewriteRule (^|/)\. - [F,L]
RewriteRule ^(app|config|database|resources|storage|vendor)/ - [F,L]

# Compatibilite hebergements partages: on sert tout depuis public/ sans regles avancees.
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L]

